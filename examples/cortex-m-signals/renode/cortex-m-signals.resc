using sysbus
mach create "cortex-m-signals"

machine LoadPlatformDescription $ORIGIN/cortex-m-signals.repl

sysbus LogPeripheralAccess signals true
sysbus.signals SystemCExecutablePath $ORIGIN/../bin/cortex-m-signals

cpu PC 0x20000000
cpu AssembleBlock 0x20000000
