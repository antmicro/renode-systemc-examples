using sysbus
mach create "dmi_test"

machine LoadPlatformDescription $ORIGIN/dmi_test.repl

sysbus LogPeripheralAccess dmi_test true
sysbus.dmi_test SimulationFilePathLinux $ORIGIN/../build/libdmi_native.so

cpu AssembleBlock 0x09000000 """
    li t0, 0x09000000
    li t1, 0x87654321
    sw t1, 0x80(t0)
    li t0, 0x09001000
    li t1, 1
    sw t1, 0(t0)
    j .
"""
