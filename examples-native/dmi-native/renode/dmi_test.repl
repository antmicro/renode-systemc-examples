memory: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x1000000
    sharedMemoryFileRoot: "/dev/shm"

cpu: CPU.RiscV32 @ sysbus
    cpuType: "rv32i"
    timeProvider: empty
    IsHalted: true

done: Miscellaneous.LED @ sysbus

unexpected_io_access: Miscellaneous.LED @ sysbus

dmi_test: SystemC.SystemCPeripheralNative @ sysbus <0x9000000, +0xffffff>
    simulationStepInNs: 1000000
    2 -> done@0
    3 -> unexpected_io_access@0
